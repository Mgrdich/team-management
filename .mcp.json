{
  "$schema": "https://modelcontextprotocol.io/schema/mcp-config.json",
  "__comment": "This is an example MCP configuration file for team-management integrations. Copy this file to .mcp.json and replace all YOUR_*_HERE placeholders with actual credentials. The .mcp.json file is gitignored to prevent credential leaks.",
  "mcpServers": {
    "GitLab": {
      "command": "npx",
      "args": [
        "mcp-remote"
      ],
      "env": {
        "GITLAB_PERSONAL_TOKEN": "${YOUR_GITLAB_TOKEN_HERE}"
      }
    },
    "atlassian": {
      "command": "npx",
      "args": [
        "mcp-remote"
      ],
      "env": {
        "ATLASSIAN_URL": "${YOUR_JIRA_URL_HERE}",
        "ATLASSIAN_EMAIL": "${YOUR_JIRA_EMAIL_HERE}",
        "ATLASSIAN_API_TOKEN": "${YOUR_JIRA_CONFLUENCE_TOKEN_HERE}"
      }
    }
  }
}
